{
  "name": "xtgzpt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "协同工作平台 Phase 1 development workspace",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "vite": {
      "esbuild": "^0.28.1"
    }
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @xtgzpt/web",
    "dev:web:lan": "npm run dev:lan -w @xtgzpt/web",
    "dev:api": "npm run dev -w @xtgzpt/api",
    "dev:api:lan": "HOST=0.0.0.0 PORT=3002 npm run dev -w @xtgzpt/api",
    "build": "npm run build -w @xtgzpt/shared && npm run build -w @xtgzpt/api && npm run build -w @xtgzpt/database && npm run build -w @xtgzpt/web",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "npm run build -w @xtgzpt/shared && vitest run",
    "smoke:api": "node --import tsx scripts/smoke.mjs",
    "live:ark": "tsx scripts/live-ark-check.mjs",
    "smoke": "npm run build && npm run smoke:api",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm run smoke:api"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.3"
  }
}
